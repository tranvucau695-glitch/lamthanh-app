# Sao chép file này thành .env và điền thông tin thật

# MongoDB Atlas connection string
# Lấy từ: MongoDB Atlas > Connect > Drivers > Copy connection string
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/lamthanh?retryWrites=true&w=majority

# Secret key để mã hóa JWT (gõ bất kỳ chuỗi dài ngẫu nhiên)
JWT_SECRET=lamthanh_secret_key_2025_xyz_abc_123

# Port (Render tự set, không cần đổi)
PORT=3000
